{
  "manifest_version": 3,
  "name": "Bubble Breakpoint Override",
  "description": "AI-powered responsive overrides for Bubble.io",
  "version": "4.0.0",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["*://*.bubble.io/page*", "*://*.bubble.is/page*"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": ["*://*.bubble.io/*", "*://*.bubble.is/*"],
      "resources": ["injected.js"]
    }
  ]
}
